{
  "name": "cloudvoyager-desktop",
  "productName": "CloudVoyager Desktop",
  "version": "1.1.1",
  "description": "Desktop UI for CloudVoyager — migrate SonarQube to SonarCloud",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build:linux-x64": "electron-builder --linux --x64",
    "build:linux-arm64": "electron-builder --linux --arm64",
    "build:mac-arm64": "electron-builder --mac --arm64",
    "build:win-x64": "electron-builder --win --x64",
    "build:win-arm64": "electron-builder --win --arm64"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
